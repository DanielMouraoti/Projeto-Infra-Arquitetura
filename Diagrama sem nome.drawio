        <UserObject label="" plantUmlData="{&quot;data&quot;:&quot;@startuml\n!theme plain\ntop to bottom direction\n\npackage \&quot;Internet\&quot; {\n    [Link NET] as NET\n    [Link VIVO] as VIVO\n}\n\n[Firewall / Edge Router\\nFailover Multi-WAN] as FW\n\npackage \&quot;Rack Principal\&quot; {\n    [Core Switch 24/48 Portas] as CORE\n    [Servidores de Teste / VMs] as SRV_TESTE\n}\n\nNET --&gt; FW\nVIVO --&gt; FW\nFW --&gt; CORE\nCORE --&gt; SRV_TESTE\n\n[Switch - Setor Infra] as SW_INFRA\n[Switch - Setor Negócios] as SW_NEG\n[Switch - Setor Dev] as SW_DEV\n[Switch - Corporativo] as SW_CORP\n\nCORE ==&gt; SW_INFRA\nCORE ==&gt; SW_NEG\nCORE ==&gt; SW_DEV\nCORE ==&gt; SW_CORP\n\npackage \&quot;VLAN 10 - Infra (4 Hosts)\&quot; {\n    [Newton] as H_NEWTON\n    [Tesla] as H_TESLA\n    [Einstein] as H_EINSTEIN\n    [Turing] as H_TURING\n}\nSW_INFRA --&gt; H_NEWTON\nSW_INFRA --&gt; H_TESLA\nSW_INFRA --&gt; H_EINSTEIN\nSW_INFRA --&gt; H_TURING\n\npackage \&quot;VLAN 20 - Negócios (10 Hosts)\&quot; {\n    [Rosalind] as H_ROSALIND\n    [Galliel] as H_GALLIEL\n    [Meucci] as H_MEUCCI\n    [Pasteur] as H_PASTEUR\n    [Bohr] as H_BOHR\n    [Franklin] as H_FRANKLIN\n    [Linus] as H_LINUS\n    [Fibonacci] as H_FIBONACCI\n    [Fleming] as H_FLEMING\n    [Bardeen] as H_BARDEEN\n}\nSW_NEG --&gt; H_ROSALIND\nSW_NEG --&gt; H_GALLIEL\nSW_NEG --&gt; H_MEUCCI\nSW_NEG --&gt; H_PASTEUR\nSW_NEG --&gt; H_BOHR\nSW_NEG --&gt; H_FRANKLIN\nSW_NEG --&gt; H_LINUS\nSW_NEG --&gt; H_FIBONACCI\nSW_NEG --&gt; H_FLEMING\nSW_NEG --&gt; H_BARDEEN\n\npackage \&quot;VLAN 30 - Desenvolvimento (8 Hosts)\&quot; {\n    [Lovelace] as H_LOVELACE\n    [Darwin] as H_DARWIN\n    [Mandeleeve] as H_MANDELEEVE\n    [Heisenberg] as H_HEISENBERG\n    [Babbage] as H_BABBAGE\n    [Torvalds] as H_TORVALDS\n    [Ritchie] as H_RITCHIE\n    [Berners-Lee] as H_BERNERS\n}\nSW_DEV --&gt; H_LOVELACE\nSW_DEV --&gt; H_DARWIN\nSW_DEV --&gt; H_MANDELEEVE\nSW_DEV --&gt; H_HEISENBERG\nSW_DEV --&gt; H_BABBAGE\nSW_DEV --&gt; H_TORVALDS\nSW_DEV --&gt; H_RITCHIE\nSW_DEV --&gt; H_BERNERS\n\npackage \&quot;VLAN 40 - Diretoria (1 Host)\&quot; {\n    [Maxwell] as H_MAXWELL\n}\nSW_CORP --&gt; H_MAXWELL\n\npackage \&quot;VLAN 50 - ESG (2 Hosts)\&quot; {\n    [Feynman] as H_FEYNMAN\n    [Gregor] as H_GREGOR\n}\nSW_CORP --&gt; H_FEYNMAN\nSW_CORP --&gt; H_GREGOR\n\npackage \&quot;VLAN 60 - Comercial (2 Hosts)\&quot; {\n    [da Vinci] as H_DAVINCI\n    [Kepler] as H_KEPLER\n}\nSW_CORP --&gt; H_DAVINCI\nSW_CORP --&gt; H_KEPLER\n\npackage \&quot;VLAN 70 - Administrativo (5 Hosts)\&quot; {\n    [Hawking (Financeiro)] as H_HAWKING\n    [Pascal (Financeiro)] as H_PASCAL\n    [Faraday (RH)] as H_FARADAY\n    [Copérnico (RH)] as H_COPERNICO\n    [Lamar (Estag RH)] as H_LAMAR\n}\nSW_CORP --&gt; H_HAWKING\nSW_CORP --&gt; H_PASCAL\nSW_CORP --&gt; H_FARADAY\nSW_CORP --&gt; H_COPERNICO\nSW_CORP --&gt; H_LAMAR\n\n@enduml&quot;,&quot;format&quot;:&quot;svg&quot;}" id="x8_S7ZFp-CIRVpqB1fQ4-1">
